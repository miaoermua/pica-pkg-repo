{
  "pica_protocol": 1,
  "schema": "pica-ci-job-v1",
  "mgr": "opkg",
  "id": "openclash",
  "enabled": true,
  "manifest": "src/opkg/openclash/manifest",
  "source": {
    "provider": "github",
    "repo": "vernesong/OpenClash",
    "release": {
      "tag": {
        "mode": "regex",
        "regex": "^v?[0-9]+(?:\\.[0-9.]+)*$"
      },
      "allow_prerelease": false,
      "assets": [
        {
          "name": "luci-app",
          "role": "luci",
          "regex": "^luci-app-openclash_.*_all\\.ipk$",
          "required": true,
          "target": {
            "platform": "all",
            "arch": "all"
          }
        }
      ]
    }
  },
  "versioning": {
    "pkgver": {
      "from": "manifest",
      "fallback": "0.47.075"
    },
    "pkgrel": {
      "from": "manifest",
      "fallback": 1
    }
  },
  "build": {
    "matrix": [
      {
        "platform": "all",
        "arch": "all"
      }
    ],
    "include_dirs": [
      "cmd",
      "binary",
      "depend",
      "src"
    ],
    "pack": {
      "tool": "pica-pack",
      "format": "pkg.tar.gz"
    }
  },
  "publish": {
    "manifest_index": "src/opkg/manifest.json",
    "registry_db": "r/opkg/openclash/db.json",
    "keep_release_history": 1
  }
}
