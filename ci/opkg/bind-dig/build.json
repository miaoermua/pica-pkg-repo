{
  "pica_protocol": 1,
  "schema": "pica-ci-job-v1",
  "mgr": "opkg",
  "id": "bind-dig",
  "enabled": true,
  "manifest": "src/opkg/bind-dig/manifest",
  "source": {
    "provider": "http_template",
    "url_template": "https://mirrors.pku.edu.cn/immortalwrt/releases/24.10-SNAPSHOT/packages/{arch}/packages/bind-dig_{version}_{arch}.ipk",
    "version": "9.20.18-r1"
  },
  "versioning": {
    "pkgver": {
      "from": "manifest",
      "fallback": "9.20.18"
    },
    "pkgrel": {
      "from": "manifest",
      "fallback": 1
    }
  },
  "build": {
    "matrix": [
      {
        "platform": "amd64",
        "arch": "x86_64"
      },
      {
        "platform": "arm64",
        "arch": "aarch64_generic"
      },
      {
        "platform": "arm64",
        "arch": "aarch64_cortex-a53"
      },
      {
        "platform": "arm64",
        "arch": "aarch64_cortex-a72"
      },
      {
        "platform": "mipsel",
        "arch": "mipsel_24kc"
      }
    ],
    "include_dirs": [
      "cmd",
      "binary",
      "depend",
      "src"
    ],
    "pack": {
      "tool": "pica-pack",
      "format": "pkg.tar.gz"
    }
  },
  "publish": {
    "manifest_index": "src/opkg/manifest.json",
    "registry_db": "r/opkg/bind-dig/db.json"
  }
}
