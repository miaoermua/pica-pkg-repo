{
  "pica_protocol": 1,
  "schema": "pica-ci-job-v1",
  "mgr": "opkg",
  "id": "openlist",
  "enabled": true,
  "manifest": "src/opkg/openlist/manifest",
  "source": {
    "provider": "http_template",
    "url_templates": [
      "https://mirrors.pku.edu.cn/immortalwrt/releases/24.10-SNAPSHOT/packages/{arch}/luci/luci-app-openlist_25.306.51720~a833d72_all.ipk",
      "https://mirrors.pku.edu.cn/immortalwrt/releases/24.10-SNAPSHOT/packages/{arch}/luci/luci-i18n-openlist-zh-cn_26.030.72349~cfd9f87_all.ipk",
      "https://mirrors.pku.edu.cn/immortalwrt/releases/24.10-SNAPSHOT/packages/{arch}/packages/openlist_4.1.5-r1_{arch}.ipk"
    ],
    "version": "4.1.5-r1"
  },
  "versioning": {
    "pkgver": {
      "from": "manifest",
      "fallback": "4.1.5"
    }
  },
  "build": {
    "matrix": [
      { "platform": "amd64", "arch": "x86_64" },
      { "platform": "arm64", "arch": "aarch64_generic" },
      { "platform": "arm64", "arch": "aarch64_cortex-a53" },
      { "platform": "arm64", "arch": "aarch64_cortex-a72" },
      { "platform": "mipsel", "arch": "mipsel_24kc" }
    ],
    "include_dirs": [
      "cmd",
      "binary",
      "depend",
      "src"
    ],
    "pack": {
      "tool": "pica-pack",
      "format": "pkg.tar.gz"
    }
  },
  "publish": {
    "manifest_index": "src/opkg/manifest.json",
    "registry_db": "r/opkg/openlist/db.json"
  }
}
