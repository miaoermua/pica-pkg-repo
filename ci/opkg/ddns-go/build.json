{
  "pica_protocol": 1,
  "schema": "pica-ci-job-v1",
  "mgr": "opkg",
  "id": "ddns-go",
  "enabled": true,
  "manifest": "src/opkg/ddns-go/manifest",
  "source": {
    "provider": "github",
    "repo": "sirpdboy/luci-app-ddns-go",
    "release": {
      "tag": {
        "mode": "regex",
        "regex": "^v6\\.9\\.1$"
      },
      "allow_prerelease": false,
      "assets": [
        {
          "name": "ddns-go-bin",
          "role": "app",
          "regex": "^ddns-go_6\\.9\\.1-r1_(.*)\\.ipk$",
          "required": true,
          "capture_to": {
            "arch": 1
          }
        },
        {
          "name": "luci-app",
          "role": "app",
          "regex": "^luci-app-ddns-go_.*_all\\.ipk$",
          "required": true,
          "target": {
            "platform": "all",
            "arch": "all"
          }
        },
        {
          "name": "luci-i18n",
          "role": "app",
          "regex": "^luci-i18n-ddns-go-zh-cn_.*_all\\.ipk$",
          "required": true,
          "target": {
            "platform": "all",
            "arch": "all"
          }
        }
      ]
    }
  },
  "versioning": {
    "pkgver": {
      "from": "manifest",
      "fallback": "6.9.1"
    }
  },
  "build": {
    "matrix": [
      { "platform": "amd64", "arch": "x86_64" },
      { "platform": "arm64", "arch": "aarch64_generic" },
      { "platform": "mipsel", "arch": "mipsel_24kc" }
    ],
    "include_dirs": [
      "cmd",
      "binary",
      "depend",
      "src"
    ],
    "pack": {
      "tool": "pica-pack",
      "format": "pkg.tar.gz"
    }
  },
  "publish": {
    "manifest_index": "src/opkg/manifest.json",
    "registry_db": "r/opkg/ddns-go/db.json"
  }
}
