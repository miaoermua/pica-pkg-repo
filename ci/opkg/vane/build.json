{
  "pica_protocol": 1,
  "schema": "pica-ci-job-v1",
  "mgr": "opkg",
  "id": "vane",
  "enabled": true,
  "manifest": "src/opkg/vane/manifest",
  "source": {
    "provider": "github",
    "repo": "canmi21/vane",
    "release": {
      "tag": {
        "mode": "regex",
        "regex": "^v?[0-9.]+$"
      },
      "allow_prerelease": false,
      "assets": [
        {
          "name": "vane-bin",
          "role": "app",
          "regex": "^vane-v.*-openwrt-(x86_64|aarch64)\\.ipk$",
          "required": true,
          "capture_to": {
            "arch": 1
          }
        }
      ]
    }
  },
  "versioning": {
    "pkgver": {
      "from": "manifest",
      "fallback": "0.9.0"
    },
    "pkgrel": {
      "from": "manifest",
      "fallback": 1
    }
  },
  "build": {
    "matrix": [
      {
        "platform": "amd64",
        "arch": "x86_64"
      },
      {
        "platform": "arm64",
        "arch": "aarch64"
      }
    ],
    "include_dirs": [
      "cmd",
      "binary",
      "depend",
      "src"
    ],
    "pack": {
      "tool": "pica-pack",
      "format": "pkg.tar.gz"
    }
  },
  "publish": {
    "manifest_index": "src/opkg/manifest.json",
    "registry_db": "r/opkg/vane/db.json",
    "keep_release_history": 1
  }
}
