{
  "pica_protocol": 1,
  "schema": "pica-ci-job-v1",
  "mgr": "opkg",
  "id": "ua-mask",
  "enabled": true,
  "manifest": "src/opkg/ua-mask/manifest",
  "source": {
    "provider": "github",
    "repo": "Zesuy/UA-Mask",
    "release": {
      "tag": {
        "mode": "regex",
        "regex": "^v0\\.4\\.3$"
      },
      "allow_prerelease": false,
      "assets": [
        {
          "name": "ua-mask-pkg",
          "role": "app",
          "regex": "^UAmask_0\\.4\\.3-1_(.*)\\.ipk$",
          "required": true,
          "capture_to": {
            "arch": 1
          }
        }
      ]
    }
  },
  "versioning": {
    "pkgver": {
      "from": "manifest",
      "fallback": "0.4.3"
    }
  },
  "build": {
    "matrix": [
      { "platform": "amd64", "arch": "x86_64" },
      { "platform": "arm64", "arch": "aarch64_generic" },
      { "platform": "arm64", "arch": "aarch64_cortex-a53" },
      { "platform": "arm64", "arch": "aarch64_cortex-a72" },
      { "platform": "mipsel", "arch": "mipsel_24kc" }
    ],
    "include_dirs": [
      "cmd",
      "binary",
      "depend",
      "src"
    ],
    "pack": {
      "tool": "pica-pack",
      "format": "pkg.tar.gz"
    }
  },
  "publish": {
    "manifest_index": "src/opkg/manifest.json",
    "registry_db": "r/opkg/ua-mask/db.json"
  }
}
