{
  "pica_protocol": 1,
  "schema": "pica-ci-job-v1",
  "mgr": "none",
  "id": "cattools",
  "enabled": true,
  "manifest": "src/none/cattools/manifest",
  "source": {
    "provider": "github",
    "repo": "miaoermua/cattools",
    "release": {
      "tag": {
        "mode": "regex",
        "regex": "^v?[0-9.]+$"
      },
      "allow_prerelease": false,
      "assets": [
        {
          "name": "cattools-script",
          "role": "app",
          "regex": "^cattools(-.*)?\\.zip$",
          "required": true,
          "target": {
            "platform": "all",
            "arch": "all"
          }
        }
      ]
    }
  },
  "versioning": {
    "pkgver": {
      "from": "manifest",
      "fallback": "1.1"
    }
  },
  "build": {
    "matrix": [
      {
        "platform": "all",
        "arch": "all"
      }
    ],
    "pack": {
      "tool": "pica-pack",
      "format": "pkg.tar.gz"
    }
  },
  "publish": {
    "manifest_index": "src/opkg/manifest.json",
    "registry_db": "r/none/cattools/db.json"
  }
}
