{
  "pica_protocol": 1,
  "schema": "pica-ci-job-v1",
  "mgr": "opkg",
  "id": "rtp2httpd",
  "enabled": true,
  "manifest": "manifests/opkg/rtp2httpd/manifest",
  "source": {
    "provider": "github",
    "repo": "stackia/rtp2httpd",
    "release": {
      "tag": {
        "mode": "regex",
        "regex": "^v?[0-9]+(?:\\.[0-9]+)*(?:[-_].+)?$"
      },
      "allow_prerelease": false,
      "assets": [
        {
          "name": "luci-app",
          "role": "luci",
          "regex": "^luci-app-rtp2httpd_.*_all\\.ipk$",
          "required": true,
          "target": {
            "platform": "all",
            "arch": "all"
          }
        },
        {
          "name": "luci-i18n-zh-cn",
          "role": "i18n",
          "regex": "^luci-i18n-rtp2httpd-zh-cn_.*_all\\.ipk$",
          "required": false,
          "target": {
            "platform": "all",
            "arch": "all"
          }
        }
      ]
    }
  },
  "versioning": {
    "pkgver": {
      "from": "manifest",
      "fallback": "3.9.1"
    },
    "pkgrel": {
      "from": "manifest",
      "fallback": 1
    }
  },
  "build": {
    "matrix": [
      {
        "platform": "all",
        "arch": "all"
      }
    ],
    "include_dirs": [
      "cmd",
      "binary",
      "depend",
      "src"
    ],
    "pack": {
      "tool": "pica-pack",
      "format": "pkg.tar.gz"
    }
  },
  "publish": {
    "manifest_index": "manifests/opkg/manifest.json",
    "registry_db": "r/opkg/rtp2httpd/db.json",
    "keep_release_history": 1,
    "artifact_url_template": "https://example.invalid/pica/releases/{id}/{filename}"
  }
}
