{
  "pica_protocol": 1,
  "schema": "pica-ci-job-v1",
  "mgr": "opkg",
  "id": "leigod-acc",
  "enabled": true,
  "manifest": "manifests/opkg/leigod-acc/manifest",
  "source": {
    "provider": "github",
    "repo": "miaoermua/luci-app-leigod-acc",
    "release": {
      "tag": {
        "mode": "regex",
        "regex": "^v?[0-9]+(?:\\.[0-9]+)*(?:[-_].+)?$"
      },
      "allow_prerelease": false,
      "assets": [
        {
          "name": "leigod-core",
          "role": "app",
          "regex": "^leigod-acc_.*_(x86_64|aarch64_generic|aarch64_cortex-a53|mipsel_24kc)\\.ipk$",
          "required": true,
          "capture_to": {
            "arch": 1
          }
        },
        {
          "name": "luci-app",
          "role": "luci",
          "regex": "^luci-app-leigod-acc_.*_all\\.ipk$",
          "required": true,
          "target": {
            "platform": "all",
            "arch": "all"
          }
        },
        {
          "name": "luci-i18n-zh-cn",
          "role": "i18n",
          "regex": "^luci-i18n-leigod-acc-zh-cn_.*_all\\.ipk$",
          "required": false,
          "target": {
            "platform": "all",
            "arch": "all"
          }
        }
      ]
    }
  },
  "versioning": {
    "pkgver": {
      "from": "manifest",
      "fallback": "1.3.0.30"
    },
    "pkgrel": {
      "from": "manifest",
      "fallback": 1
    }
  },
  "build": {
    "matrix": [
      {
        "platform": "amd64",
        "arch": "x86_64"
      },
      {
        "platform": "arm64",
        "arch": "aarch64_generic"
      },
      {
        "platform": "arm64",
        "arch": "aarch64_cortex-a53"
      },
      {
        "platform": "mipsel",
        "arch": "mipsel_24kc"
      }
    ],
    "include_dirs": [
      "cmd",
      "binary",
      "depend",
      "src"
    ],
    "pack": {
      "tool": "pica-pack",
      "format": "pkg.tar.gz"
    }
  },
  "publish": {
    "manifest_index": "manifests/opkg/manifest.json",
    "registry_db": "r/opkg/leigod-acc/db.json",
    "keep_release_history": 1,
    "artifact_url_template": "https://example.invalid/pica/releases/{id}/{filename}"
  }
}
