{
  "pica_protocol": 1,
  "schema": "pica-ci-job-v1",
  "mgr": "opkg",
  "id": "rtp2httpd-jarod360",
  "enabled": true,
  "manifest": "manifests/opkg/rtp2httpd-jarod360/manifest",
  "source": {
    "provider": "github",
    "repo": "jarod360/rtp2httpd",
    "release": {
      "tag": {
        "mode": "regex",
        "regex": "^v?[0-9]+(?:\\.[0-9]+)*(?:[-_].+)?$"
      },
      "allow_prerelease": false,
      "assets": [
        {
          "name": "rtp2httpd-core",
          "role": "app",
          "regex": "^rtp2httpd_.*_(x86_64|aarch64_generic|aarch64_cortex-a53)\\.ipk$",
          "required": true,
          "capture_to": {
            "arch": 1
          }
        },
        {
          "name": "luci-app",
          "role": "luci",
          "regex": "^luci-app-rtp2httpd_.*_all\\.ipk$",
          "required": true,
          "target": {
            "platform": "all",
            "arch": "all"
          }
        }
      ]
    }
  },
  "versioning": {
    "pkgver": {
      "from": "manifest",
      "fallback": "20251127"
    },
    "pkgrel": {
      "from": "manifest",
      "fallback": 2
    }
  },
  "build": {
    "matrix": [
      {
        "platform": "amd64",
        "arch": "x86_64"
      },
      {
        "platform": "arm64",
        "arch": "aarch64_generic"
      },
      {
        "platform": "arm64",
        "arch": "aarch64_cortex-a53"
      }
    ],
    "include_dirs": [
      "cmd",
      "binary",
      "depend",
      "src"
    ],
    "pack": {
      "tool": "pica-pack",
      "format": "pkg.tar.gz"
    }
  },
  "publish": {
    "manifest_index": "manifests/opkg/manifest.json",
    "registry_db": "r/opkg/rtp2httpd-jarod360/db.json",
    "keep_release_history": 1,
    "artifact_url_template": "https://example.invalid/pica/releases/{id}/{filename}"
  }
}
