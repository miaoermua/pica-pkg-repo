{
  "pica_protocol": 1,
  "schema": "pica-ci-job-v1",
  "mgr": "none",
  "id": "cattools",
  "enabled": true,
  "manifest": "manifests/none/cattools/manifest",
  "source": {
    "provider": "git",
    "repo": "https://github.com/miaoermua/cattools.git",
    "ref": {
      "mode": "regex",
      "regex": "^v?[0-9]+(?:\\.[0-9]+)*(?:[-_].+)?$"
    }
  },
  "versioning": {
    "pkgver": {
      "from": "manifest",
      "fallback": "1.1"
    },
    "pkgrel": {
      "from": "manifest",
      "fallback": 1
    }
  },
  "build": {
    "matrix": [
      {
        "platform": "all",
        "arch": "all"
      }
    ],
    "include_dirs": [
      "cmd",
      "src"
    ],
    "pack": {
      "tool": "pica-pack",
      "format": "pkg.tar.gz"
    }
  },
  "publish": {
    "manifest_index": "manifests/none/manifest.json",
    "registry_db": "r/none/cattools/db.json",
    "keep_release_history": 1,
    "artifact_url_template": "https://example.invalid/pica/releases/{id}/{filename}"
  }
}
